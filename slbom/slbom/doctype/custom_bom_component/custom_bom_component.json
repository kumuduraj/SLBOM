{
  "name": "Custom BOM Component",
  "module": "SLBOM",
  "doctype": "DocType",
  "document_type": "",
  "engine": "InnoDB",
  "istable": 1,
  "editable_grid": 1,
  "track_changes": 0,
  "fields": [
    {
      "fieldname": "item",
      "fieldtype": "Link",
      "label": "Item",
      "options": "Item",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 3
    },
    {
      "fieldname": "item_name",
      "fieldtype": "Data",
      "label": "Item Name",
      "fetch_from": "item.item_name",
      "read_only": 1,
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "item_group",
      "fieldtype": "Data",
      "label": "Item Group",
      "fetch_from": "item.item_group",
      "read_only": 1
    },
    {
      "fieldname": "uom",
      "fieldtype": "Link",
      "label": "UOM",
      "options": "UOM",
