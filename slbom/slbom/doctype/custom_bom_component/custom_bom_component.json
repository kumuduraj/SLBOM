      "columns": 1,
      "description": "Auto-pulled from Item Price; editable"
    },
    {
      "fieldname": "price_list",
      "fieldtype": "Link",
      "label": "Price List",
      "options": "Price List",
      "description": "Source price list for rate lookup"
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount",
      "read_only": 1,
      "in_list_view": 1,
      "columns": 1,
      "description": "qty x rate; auto-computed"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
